    {
        "id": "b5b598c74f2c86b4",
        "type": "function",
        "z": "1960d6e236eb1970",
        "name": "function 28",
        "func": "// 1. Initialize context to track the device\nvar alertedDevices = context.get(\"alertedDevices\") || {};\nvar now = Date.now();\n\n// 2. Configuration\nvar cooldown = 9 * 60 * 1000; // 9 Minutes\nvar maxAlerts = 2; \n\n// 3. Extract MAC safely\nvar data = msg.payload.uplink_message.decoded_payload;\nif (!data) return null;\n\nvar mac = data.mac_hash || \"Unknown\";\n\nif (!alertedDevices[mac]) {\n    alertedDevices[mac] = { count: 0, lastTime: 0 };\n}\n\nvar device = alertedDevices[mac];\n\n// 4. Reset counter if cooldown has passed\nif (now - device.lastTime > cooldown) {\n    device.count = 0;\n}\n\n// 5. Alert Blocking Logic\nif (data.status === \"alert\" && device.count >= maxAlerts) {\n    var minsAgo = Math.round((now - device.lastTime) / 60000);\n    node.status({ fill: \"yellow\", shape: \"ring\", text: \"Silent: \" + mac + \" (\" + minsAgo + \"m ago)\" });\n    return null; \n}\n\n// 6. Update state\nif (data.status === \"alert\") {\n    device.count++;\n}\ndevice.lastTime = now;\nalertedDevices[mac] = device;\ncontext.set(\"alertedDevices\", alertedDevices);\n\n// 7. Pass metadata to the next node\nmsg.alertCount = device.count;\n\nnode.status({ \n    fill: data.status === \"alert\" ? \"red\" : \"green\", \n    shape: \"dot\", \n    text: data.status.toUpperCase() + \" | \" + mac + \" (Cnt: \" + device.count + \")\" \n});\n\nreturn msg;",
        "outputs": 1,
        "timeout": 0,
        "noerr": 0,
