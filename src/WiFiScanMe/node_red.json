        "height": 2,
        "format": "<div style=\"display: flex; align-items: center; justify-content: space-between; background: #1a1a1a; padding: 10px; border-radius: 8px; border: 1px solid #333;\">\n    <span style=\"color: #eee; font-weight: bold; font-size: 14px;\">Hek Sinkronisasie</span>\n    <div style=\"width: 16px; height: 16px; border-radius: 50%; \n                background-color: {{msg.payload}}; \n                box-shadow: 0 0 12px {{msg.payload}}; \n                transition: all 0.5s ease;\">\n    </div>\n</div>",
        "storeOutMessages": true,
