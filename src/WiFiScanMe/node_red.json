    {
        "id": "552656d36f946b40",
        "type": "function",
        "z": "1960d6e236eb1970",
        "name": "Format Telegram Alert",
        "func": "// 1. Safety Check - Ensure payload and decoded data exist\nif (!msg.payload || !msg.payload.uplink_message || !msg.payload.uplink_message.decoded_payload) {\n    return null;\n}\n\nvar data = msg.payload.uplink_message.decoded_payload;\nvar vbat = parseFloat(data.voltage) || 0;\nvar now = new Date();\nvar timeStr = now.toLocaleTimeString('en-GB', { hour: '2-digit', minute: '2-digit', second: '2-digit' });\n\n// --- DUAL SYNC CHECK ---\n// Get current hardware value from the JSON you just received\nvar currentLimit = Math.abs(parseInt(data.rssi_limit || 0));\n\n// Get your target value from the dashboard slider (stored in global memory)\nvar targetLimit = Math.abs(parseInt(global.get(\"gate_rssi_limit\") || 70));\n\n// Logic: Green if the hardware (70) matches your slider (70)\nvar isSynced = (currentLimit === targetLimit);\nvar lightColor = isSynced ? \"green\" : \"yellow\";\n\n// If synced, update the Last Sync timestamp\nif (isSynced) {\n    global.set(\"gate_last_sync\", timeStr);\n}\n\n// --- RSSI & DISTANCE PROCESSING ---\nvar rssi_intruder = data.rssi || 0;\nif (rssi_intruder > 0) { rssi_intruder = -rssi_intruder; }\nvar distance = data.distance_meters || 0;\n\n// --- 2. PREPARE UI MESSAGES (Output 3) ---\nvar uiMsg = {\n    payload: {\n        vbat: vbat.toFixed(3),\n        limit: -currentLimit,\n        intruder: rssi_intruder,\n        distance: distance + \"m\",\n        status: data.status,\n        timestamp: timeStr,\n        lastSync: global.get(\"gate_last_sync\") || \"Geen\"\n    }\n};\n\n// --- 3. PREPARE STATUS LIGHT (Output 4) ---\nvar statusLightMsg = { payload: lightColor };\n\n// --- 4. TELEGRAM & DEBUG LOGIC ---\nif (data.status === \"alert\") {\n    var telegramText = \"🚨 *KLEIN SMALDEEL ALERT* 🚨\\n\";\n    telegramText += \"━━━━━━━━━━━━━━━\\n\";\n    telegramText += \"📍 *Afstand:* ~\" + distance + \"m\\n\";\n    telegramText += \"📶 *Sein:* \" + rssi_intruder + \" dBm\\n\";\n    telegramText += \"🔋 *Battery:* \" + vbat.toFixed(2) + \"V\\n\";\n    telegramText += \"🕒 *Tyd:* \" + timeStr;\n\n    var telegramMsg = {\n        payload: {\n            chatId: \"1097339763\",\n            type: \"message\",\n            content: telegramText,\n            options: { parse_mode: \"Markdown\" }\n        }\n    };\n\n    node.status({ fill: \"red\", shape: \"dot\", text: \"ALERT SENT | Sync: \" + lightColor });\n    return [telegramMsg, telegramMsg, uiMsg, statusLightMsg];\n    \n} else {\n    node.status({ \n        fill: lightColor, \n        shape: isSynced ? \"dot\" : \"ring\", \n        text: \"Sync: \" + lightColor + \" (-\" + currentLimit + \"dBm)\" \n    });\n    return [null, null, uiMsg, statusLightMsg];\n}",
        "outputs": 4,
        "timeout": "",
        "noerr": 0,
        "initialize": "",
        "finalize": "",
