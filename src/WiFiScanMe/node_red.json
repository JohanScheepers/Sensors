    {
        "id": "3e5666117dcdc943",
        "type": "function",
        "z": "1960d6e236eb1970",
        "name": "function 4",
        "func": "// 1. Get input from the sliders (RSSI or Heartbeat)\nvar input = parseInt(msg.payload);\n\n// 2. Retrieve existing values from Global Memory\n// We set defaults here (70 and 10) in case the globals are empty/null\nvar threshold = global.get(\"gate_rssi_limit\") || 70;\nvar heartbeat = global.get(\"gate_heartbeat_interval\") || 10;\n\n// 3. Update the specific value based on which slider was moved\nif (input < 0) { \n    // Slider was RSSI (e.g., -95)\n    threshold = Math.abs(input); \n    global.set(\"gate_rssi_limit\", threshold); \n} else if (input > 0) {\n    // Slider was Heartbeat (e.g., 15)\n    heartbeat = input;\n    global.set(\"gate_heartbeat_interval\", heartbeat);\n}\n\n// 4. Final Safety: Ensure we never send 0 to the hardware\nif (threshold === 0) threshold = 70;\nif (heartbeat === 0) heartbeat = 10;\n\n// 5. Build the TTN Downlink (2 Bytes: [RSSI, Heartbeat])\nvar dlink = {\n    payload: {\n        \"downlinks\": [{\n            \"frm_payload\": Buffer.from([threshold, heartbeat]).toString('base64'),\n            \"f_port\": 2,\n            \"confirmed\": false, \n            \"priority\": \"NORMAL\"\n        }]\n    }\n};\n\n// 6. Update UI Status to 'Blue' (Command Queued in TTN)\nnode.status({\n    fill: \"blue\", \n    shape: \"dot\", \n    text: \"Queued: -\" + threshold + \"dBm, \" + heartbeat + \"m\"\n});\n\n// Output 1: To MQTT Out | Output 2: To Status Light Template\nreturn [dlink, { payload: \"blue\" }];",
        "outputs": 2,
        "timeout": 0,
        "noerr": 0,
        "initialize": "",
        "finalize": "",
